{
  "name": "api",
  "version": "0.1.0",
  "main": "index.js",
  "private": true,
  "scripts": {
    "start": "node -r dotenv/config build/server.js",
    "watch": "concurrently -k -p \"[{name}]\" -n \"TypeScript,Node\" -c \"yellow.bold,cyan.bold,green.bold\" \"npm run watch-ts\" \"npm run watch-node\"",
    "debug": "yarn run build && node -r dotenv/config --inspect build/server.js",
    "build": "yarn run eslint && yarn run build-ts",
    "postbuild": "copyfiles -u 1 \"src/emails/**\" build && copyfiles -u 1 \"src/reports/**\" build && copyfiles -u 1 src/images/*.png build",
    "watch-node": "nodemon -r dotenv/config build/server.js",
    "build-ts": "tsc",
    "watch-ts": "tsc -w",
    "eslint": "eslint -c .eslintrc.json 'src/**'",
    "start:prod": "NODE_ENV=production node -r dotenv/config build/server.js",
    "services:up": "docker-compose --project-directory=../deploy/docker --file=../deploy/docker/docker-compose.yml up -d",
    "services:down": "docker-compose --project-directory=../deploy/docker --file=../deploy/docker/docker-compose.yml down",
    "services:reset": "yarn services:down && yarn services:up"
  },
  "dependencies": {
    "@google/genai": "^0.12.0",
    "@types/cors": "^2.8.8",
    "@types/html-pdf": "^3.0.2",
    "@types/lodash": "^4.14.197",
    "@types/multer-s3": "^2.7.7",
    "argon2": "^0.24.0",
    "aws-sdk": "^2.463.0",
    "axios": "^0.27.2",
    "body-parser": "^1.18.3",
    "cors": "^2.8.5",
    "date-fns": "^2.9.0",
    "dotenv": "^6.2.0",
    "email-templates": "^5.0.5",
    "errorhandler": "^1.5.0",
    "express": "^4.16.1",
    "express-async-handler": "^1.1.4",
    "express-http-context": "^1.2.4",
    "express-validator": "^6.1.1",
    "firebase-admin": "^12.4.0",
    "generate-password": "^1.4.1",
    "google-auth-library": "9.14.1",
    "googleapis": "144.0.0",
    "handlebars": "^4.7.6",
    "handy-redis": "^1.5.2",
    "http-status-codes": "^1.3.1",
    "multer": "^1.4.2",
    "multer-s3": "^2.9.0",
    "nodemailer": "^6.2.1",
    "openai": "^4.102.0",
    "passport": "^0.4.0",
    "passport-jwt": "^4.0.0",
    "passport-local": "^1.0.0",
    "password-validator": "^4.1.1",
    "pdf-lib": "^1.17.1",
    "pg": "^8.2.1",
    "pg-hstore": "^2.3.2",
    "pug": "^2.0.3",
    "puppeteer": "19.11.1",
    "reflect-metadata": "^0.1.13",
    "sequelize": "^5.21.7",
    "sharp": "^0.33.5",
    "tslib": "^2.0.0",
    "uuid": "^3.3.2",
    "winston": "^3.2.1",
    "winston-daily-rotate-file": "^3.8.0"
  },
  "devDependencies": {
    "@firebase/app-types": "0.x",
    "@types/bluebird": "^3.5.27",
    "@types/body-parser": "^1.17.0",
    "@types/dotenv": "^6.1.0",
    "@types/email-templates": "^3.5.1",
    "@types/errorhandler": "^0.0.32",
    "@types/express": "^4.16.1",
    "@types/node": "^20.14.10",
    "@types/nodemailer": "^6.1.1",
    "@types/passport": "^1.0.0",
    "@types/passport-jwt": "^3.0.1",
    "@types/passport-local": "^1.0.33",
    "@types/pug": "^2.0.4",
    "@types/uuid": "^3.4.4",
    "@types/validator": "^10.11.0",
    "@typescript-eslint/eslint-plugin": "^4.6.1",
    "@typescript-eslint/parser": "^4.6.1",
    "concurrently": "^4.1.0",
    "copyfiles": "^2.1.0",
    "eslint": "^7.25.0",
    "eslint-config-prettier": "^8.0.0",
    "eslint-plugin-prettier": "^3.4.0",
    "nodemon": "^1.18.10",
    "prettier": "^1.17.0",
    "ts-node": "^8.0.3",
    "typescript": "^4.7.2"
  },
  "resolutions": {
    "@types/serve-static": "1.13.9"
  }
}
